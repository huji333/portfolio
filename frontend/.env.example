NODE_ENV=development

# Rails API URL
# ブラウザ→API (必須)
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:3000/api
# SSR→API (省略時は NEXT_PUBLIC_API_BASE_URL を使用)
# API_BASE_URL=http://backend:3000/api

# CDN (CloudFront)
# next/image の remotePatterns に追加される。未設定でも起動可能。
NEXT_PUBLIC_CLOUDFRONT_BASE_URL=https://xxxxxxxx.cloudfront.net

# S3 ダイレクトアクセス用ホスト名 (任意)
# CloudFront 経由なら不要。S3 直の URL を next/image で使う場合のみ設定。
# 例: mybucket.s3.ap-northeast-1.amazonaws.com
# NEXT_PUBLIC_S3_HOSTNAME=
