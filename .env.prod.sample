# docker-compose.prod.yml 用の環境変数サンプル
# cp .env.prod.sample .env.prod して実際の値を入れる (.env.prod は .gitignore 済み)

# ---- Database ----
BACKEND_DATABASE_PASSWORD=your_strong_db_password_here

# ---- Rails ----
# bin/rails secret で生成 (RAILS_MASTER_KEY がある場合は不要)
SECRET_KEY_BASE=your_secret_key_base_here
RAILS_MASTER_KEY=your_master_key_here

# ---- CORS ----
FRONTEND_ORIGIN=https://yourdomain.com

# ---- Host Authorization (Rails) ----
# カンマ区切りで許可するホストを指定。未設定の場合は全ホスト許可。
RAILS_ALLOWED_HOSTS=api.yourdomain.com

# ---- AWS / S3 ----
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=ap-northeast-1
AWS_BUCKET=your-bucket-name

# ---- CDN (CloudFront) ----
CLOUDFRONT_BASE_URL=https://xxxxxxxx.cloudfront.net

# ---- Frontend build args (docker-compose 変数置換で使用) ----
NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com/api
NEXT_PUBLIC_CLOUDFRONT_BASE_URL=https://xxxxxxxx.cloudfront.net
# S3 直アクセスが必要な場合のみ設定 (CloudFront 経由なら空でよい)
NEXT_PUBLIC_S3_HOSTNAME=
