#!/usr/bin/env bash
set -euo pipefail

# ──────────────────────────────────────────────
# bin/backup-db — PostgreSQL バックアップ
#
# Usage:
#   bash bin/backup-db                     # デフォルト: ./backups に保存、7日分保持
#   BACKUP_DIR=/mnt/nas/db bash bin/backup-db
#   BACKUP_KEEP_DAYS=30 bash bin/backup-db
#
# cron 例 (毎日 3:00):
#   0 3 * * * cd /path/to/portfolio && bash bin/backup-db >> /var/log/backup-db.log 2>&1
# ──────────────────────────────────────────────

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
COMPOSE_FILE="$ROOT/docker-compose.prod.yml"
BACKUP_DIR="${BACKUP_DIR:-$ROOT/backups}"
BACKUP_KEEP_DAYS="${BACKUP_KEEP_DAYS:-7}"
TIMESTAMP="$(date +%Y%m%d-%H%M%S)"
FILENAME="portfolio_${TIMESTAMP}.sql.gz"

# ---------- pre-flight ----------

if [ ! -f "$COMPOSE_FILE" ]; then
  echo "ERROR: $COMPOSE_FILE が見つかりません" >&2
  exit 1
fi

mkdir -p "$BACKUP_DIR"

# ---------- dump ----------

echo "[$(date -Iseconds)] バックアップ開始: $FILENAME"

docker compose -f "$COMPOSE_FILE" exec -T db \
  pg_dump -U backend -d backend_production --no-owner --no-acl \
  | gzip > "$BACKUP_DIR/$FILENAME"

SIZE="$(du -h "$BACKUP_DIR/$FILENAME" | cut -f1)"
echo "[$(date -Iseconds)] 完了: $FILENAME ($SIZE)"

# ---------- rotate ----------

DELETED=0
find "$BACKUP_DIR" -name "portfolio_*.sql.gz" -mtime +"$BACKUP_KEEP_DAYS" -print -delete | while read -r f; do
  DELETED=$((DELETED + 1))
  echo "[$(date -Iseconds)] 削除: $(basename "$f")"
done

echo "[$(date -Iseconds)] バックアップ完了"
