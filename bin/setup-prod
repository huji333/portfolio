#!/usr/bin/env bash
set -euo pipefail

# ──────────────────────────────────────────────
# bin/setup-prod — 本番環境の初期セットアップ
# Usage: bash bin/setup-prod
# ──────────────────────────────────────────────

ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# ---------- helpers ----------

generate_secret() {
  openssl rand -hex 32
}

prompt_or_default() {
  local prompt="$1" default="$2" var
  printf '%s [%s]: ' "$prompt" "$default" >&2
  read -r var
  echo "${var:-$default}"
}

prompt_required() {
  local prompt="$1" var
  while true; do
    printf '%s: ' "$prompt" >&2
    read -r var
    if [ -n "$var" ]; then
      echo "$var"
      return
    fi
    echo "  ⚠ 値を入力してください" >&2
  done
}

# ---------- .env ----------

setup_env_prod() {
  local target="$ROOT/.env"
  local sample="$ROOT/.env.sample"

  if [ -f "$target" ]; then
    echo "✔ .env は既に存在します（スキップ）"
    return
  fi

  if [ ! -f "$sample" ]; then
    echo "✖ .env.sample が見つかりません" >&2
    exit 1
  fi

  echo ""
  echo "── .env を生成します ──"

  local db_password
  db_password="$(generate_secret)"
  echo "  DB パスワードを自動生成しました"

  local secret_key_base
  secret_key_base="$(generate_secret)"
  echo "  SECRET_KEY_BASE を自動生成しました"

  local rails_master_key
  rails_master_key="$(prompt_required "RAILS_MASTER_KEY (config/master.key の値)")"

  local domain
  domain="$(prompt_required "ドメイン名 (例: example.com)")"

  local aws_access_key_id
  aws_access_key_id="$(prompt_required "AWS_ACCESS_KEY_ID")"

  local aws_secret_access_key
  aws_secret_access_key="$(prompt_required "AWS_SECRET_ACCESS_KEY")"

  local aws_region
  aws_region="$(prompt_or_default "AWS_REGION" "ap-northeast-1")"

  local aws_bucket
  aws_bucket="$(prompt_required "AWS_BUCKET")"

  local cloudfront_base_url
  cloudfront_base_url="$(prompt_required "CLOUDFRONT_BASE_URL (例: https://xxxxxxxx.cloudfront.net)")"

  cat > "$target" <<EOF
# docker compose (prod) 用の環境変数
# Generated by bin/setup-prod

# ---- Database ----
BACKEND_DATABASE_PASSWORD=${db_password}

# ---- Rails ----
SECRET_KEY_BASE=${secret_key_base}
RAILS_MASTER_KEY=${rails_master_key}

# ---- CORS ----
FRONTEND_ORIGIN=https://${domain}

# ---- Host Authorization (Rails) ----
RAILS_ALLOWED_HOSTS=api.${domain}

# ---- AWS / S3 ----
AWS_ACCESS_KEY_ID=${aws_access_key_id}
AWS_SECRET_ACCESS_KEY=${aws_secret_access_key}
AWS_REGION=${aws_region}
AWS_BUCKET=${aws_bucket}

# ---- CDN (CloudFront) ----
CLOUDFRONT_BASE_URL=${cloudfront_base_url}

# ---- Frontend build args ----
NEXT_PUBLIC_API_BASE_URL=https://api.${domain}/api
NEXT_PUBLIC_CLOUDFRONT_BASE_URL=${cloudfront_base_url}
NEXT_PUBLIC_S3_HOSTNAME=
EOF

  echo ""
  echo "✔ .env を生成しました"
}

# ---------- Caddyfile ----------

setup_caddyfile() {
  local target="$ROOT/Caddyfile"
  local example="$ROOT/Caddyfile.example"

  if [ -f "$target" ]; then
    echo "✔ Caddyfile は既に存在します（スキップ）"
    return
  fi

  if [ ! -f "$example" ]; then
    echo "✖ Caddyfile.example が見つかりません" >&2
    exit 1
  fi

  # .env からドメインを読み取る（先に生成されている前提）
  local domain=""
  if [ -f "$ROOT/.env" ]; then
    domain="$(grep '^FRONTEND_ORIGIN=' "$ROOT/.env" | sed 's|^FRONTEND_ORIGIN=https://||')"
  fi

  if [ -z "$domain" ]; then
    domain="$(prompt_required "ドメイン名 (例: example.com)")"
  fi

  sed "s/yourdomain\.com/${domain}/g" "$example" > "$target"

  echo "✔ Caddyfile を生成しました (ドメイン: ${domain})"
}

# ---------- main ----------

echo "=============================="
echo " Portfolio 本番セットアップ"
echo "=============================="

setup_env_prod
setup_caddyfile

echo ""
echo "── セットアップ完了 ──"
echo ""
echo "次のステップ:"
echo "  1. .env の内容を確認・調整"
echo "  2. docker compose -f docker-compose.prod.yml up -d --build"
echo ""
